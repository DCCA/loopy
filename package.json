{
  "name": "loopy",
  "version": "0.1.0",
  "description": "A library of reusable automation loops for software teams.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./loops/auto-docs": {
      "types": "./dist/loops/auto-docs/index.d.ts",
      "default": "./dist/loops/auto-docs/index.js"
    },
    "./loops/dep-updates": {
      "types": "./dist/loops/dep-updates/index.d.ts",
      "default": "./dist/loops/dep-updates/index.js"
    },
    "./loops/changelog": {
      "types": "./dist/loops/changelog/index.d.ts",
      "default": "./dist/loops/changelog/index.js"
    }
  },
  "files": [
    "dist",
    "loops/*/loop.yaml",
    "loops/*/playbook.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
